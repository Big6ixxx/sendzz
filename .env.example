# ===========================================
# SENDZZ ENVIRONMENT CONFIGURATION
# ===========================================

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# SUPABASE
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ===========================================
# BITNOB API (Off-ramp)
# ===========================================
BITNOB_API_KEY=""
BITNOB_CLIENT_ID=""

# ===========================================
# DECENTRALIZED IDENTITY & WALLETS
# ===========================================
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# RPC URLs
# Mainnet: https://mainnet.base.org
# Sepolia: https://sepolia.base.org
NEXT_PUBLIC_RPC_URL=""

# ===========================================
# SIMULATION MODE
# ===========================================
# Set to 'false' for production (Base Mainnet)
# Set to 'true' for simulation (Base Sepolia testnet)
NEXT_PUBLIC_SIMULATION_MODE=false

# ===========================================
# CIRCLE (Cross-chain USDC / CCTP)
# ===========================================
CIRCLE_API_KEY=""

# ===========================================
# PAYCREST
# ===========================================
PAYCREST_API_KEY=""
PAYCREST_API_SECRET=""
NEXT_PUBLIC_PAYCREST_API_URL="https://api.paycrest.io"

NEXT_PUBLIC_CIRCLE_CLIENT_KEY=""
NEXT_PUBLIC_CIRCLE_READ_URL="https://api.circle.com/v1/w3s/modular/rpc"
NEXT_PUBLIC_CIRCLE_SEND_URL="https://modular-sdk.circle.com/v1/rpc/w3s/buidl"
NEXT_PUBLIC_ALCHEMY_API_KEY=""

# Circle Gas Station Policy IDs — one per source chain
# Get these from the Circle Developer Console → Gas Station → Policies
# Create a separate policy for each chain you want to sponsor gas on
NEXT_PUBLIC_CIRCLE_GAS_POLICY_ARBITRUM=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_AVALANCHE=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_ETHEREUM=""

RESEND_API_KEY=""