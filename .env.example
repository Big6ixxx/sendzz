# ==============================================================================
# SENDZZ ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' (or '.env.local' / '.env.production') and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser/client-side.
# All other variables are kept secret and are only available on the server-side.

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------

# The public URL of the application. Used for generating absolute URLs, OAuth redirects, and callback URLs.
# - Dev: http://localhost:3000
# - Prod: https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Simulation Mode toggles the app between Sandbox/Testnet and Production/Mainnet.
# - Set to "true" to use Sepolia testnets, sandbox API environments, and mock behaviors.
# - Set to "false" to use Base Mainnet, Solana/Stellar Mainnets, and live API endpoints.
NEXT_PUBLIC_SIMULATION_MODE="false"

# Comma-separated list of emails with administrative privileges (e.g., admin@sendzz.io,manager@sendzz.io).
ADMIN_EMAILS=""

# Shared secret key used to authorize and secure scheduled cron job endpoints.
CRON_SECRET=""


# ------------------------------------------------------------------------------
# 2. SUPABASE (Database, Auth, and Storage Backend)
# ------------------------------------------------------------------------------
# Obtain these from the Supabase Dashboard -> Project Settings -> API.
# Website: https://supabase.com

# The base URL of your Supabase project (e.g., https://xyz.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=""

# The public anonymous key. Safe to expose to the client; respects Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# The secret service role key. Keep secret! Used by backend/serverless functions to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=""


# ------------------------------------------------------------------------------
# 3. PRIVY (Decentralized Identity & Embedded Wallets)
# ------------------------------------------------------------------------------
# Obtain these from the Privy Developer Dashboard.
# Website: https://dashboard.privy.io

# The public App ID used to initialize the Privy SDK on the client side.
NEXT_PUBLIC_PRIVY_APP_ID=""

# The secret app key used on the server side to authenticate Privy API requests.
PRIVY_APP_SECRET=""

# Authorization key for server-side wallet signing (rawSign, etc.)
# Generate this in: Privy Dashboard → Wallet infrastructure → Authorization keys → New key
# Copy the private key shown (Privy never stores it — you must save it now).
# This is a base64-encoded PKCS8 P-256 private key (no PEM headers, no wallet-auth: prefix).
# Without this, server-side Stellar transaction signing will fail with a 401 error.
PRIVY_AUTHORIZATION_PRIVATE_KEY=""

# The key quorum ID associated with the authorization key above.
# Also shown in the Privy Dashboard when you create/view the authorization key.
# Looks like: key-quorum-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# The frontend uses this to grant the server signing access to user wallets (addSigners).
PRIVY_KEY_QUORUM_ID=""


# ------------------------------------------------------------------------------
# 4. EVM NODE INFRASTRUCTURE (Base & RPC Provider)
# ------------------------------------------------------------------------------
# Obtain an API key from Alchemy (https://alchemy.com) or similar node providers.

# The EVM JSON-RPC URL for the app to communicate with the blockchain.
# - Mainnet: https://mainnet.base.org or your custom RPC
# - Sepolia: https://sepolia.base.org or your custom RPC
NEXT_PUBLIC_RPC_URL=""

# API Key for Alchemy. Used for token querying, transaction execution, and RPC reliability.
NEXT_PUBLIC_ALCHEMY_API_KEY=""

# --- Private/Backend RPC Overrides ---
# Custom server-side RPC endpoints for scanning cross-chain token balances.
# If left blank, these will default to Alchemy mainnet URLs (using NEXT_PUBLIC_ALCHEMY_API_KEY) or standard public endpoints.
ETHEREUM_RPC_URL=""
ARBITRUM_RPC_URL=""
AVALANCHE_RPC_URL=""
OPTIMISM_RPC_URL=""
POLYGON_RPC_URL=""


# ------------------------------------------------------------------------------
# 5. CIRCLE WEB3 SERVICES (Programmable Wallets & CCTP Bridge)
# ------------------------------------------------------------------------------
# Obtain from the Circle Developer Console.
# Website: https://console.circle.com

# Master secret API Key for Circle developer APIs.
CIRCLE_API_KEY=""

# A 32-byte hex-encoded secret key used to encrypt client-side requests for Web3 Wallets.
CIRCLE_ENTITY_SECRET=""

# Public client key for authenticating wallet interactions in the frontend.
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=""

# The Circle Web3 Services read-only JSON-RPC endpoint.
# Default: https://api.circle.com/v1/w3s/modular/rpc
NEXT_PUBLIC_CIRCLE_READ_URL="https://api.circle.com/v1/w3s/modular/rpc"

# The Circle Web3 Services send-only transaction execution RPC endpoint.
# Default: https://modular-sdk.circle.com/v1/rpc/w3s/buidl
NEXT_PUBLIC_CIRCLE_SEND_URL="https://modular-sdk.circle.com/v1/rpc/w3s/buidl"

# Circle's Solana Wallet ID configured to act as the transaction fee payer on Solana.
CIRCLE_SOLANA_FEEPAYER_WALLET_ID=""

# The base58 Solana public key for the fee payer wallet (ID above). Find this in the Circle console.
CIRCLE_SOLANA_FEEPAYER_ADDRESS=""


# ------------------------------------------------------------------------------
# 6. CIRCLE GAS STATION POLICIES
# ------------------------------------------------------------------------------
# Policy IDs used to sponsor gas (relayer fees) for users transacting on specific chains.
# Obtain these from Circle Developer Console -> Gas Station -> Policies.
# Create a policy for each target chain and paste the generated IDs here.
NEXT_PUBLIC_CIRCLE_GAS_POLICY_ARBITRUM=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_AVALANCHE=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_ETHEREUM=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_OPTIMISM=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_POLYGON=""
NEXT_PUBLIC_CIRCLE_GAS_POLICY_SOLANA=""


# ------------------------------------------------------------------------------
# 7. FIAT ON/OFF RAMPS (Bitnob & Paycrest)
# ------------------------------------------------------------------------------

# --- Bitnob (African Local Ramps) ---
# Obtain from Sandbox (https://sandbox.bitnob.com) or Production (https://dashboard.bitnob.com).
BITNOB_API_KEY=""
BITNOB_CLIENT_ID=""

# --- Paycrest ---
# Obtain from the Paycrest Merchant Dashboard (https://paycrest.io).
PAYCREST_API_KEY=""
PAYCREST_API_SECRET=""
NEXT_PUBLIC_PAYCREST_API_URL="https://api.paycrest.io"


# ------------------------------------------------------------------------------
# 8. EMAIL DELIVERY SERVICE (Resend)
# ------------------------------------------------------------------------------
# Obtain an API key from the Resend Dashboard -> API Keys.
# Website: https://resend.com
RESEND_API_KEY=""

# The sender email address (e.g. transactional@sendzz.io or hello@yourdomain.com).
# Defaults to "noreply@sendzz.io" if not specified.
EMAIL_FROM_ADDRESS=""


# ------------------------------------------------------------------------------
# 10. TWO-FACTOR AUTHENTICATION (2FA) SECURITY
# ------------------------------------------------------------------------------

# A 32+ character random secret key used to encrypt TOTP secrets.
# Generate with: openssl rand -base64 32
# Keep this key secure and never expose it to the client-side.
TOTP_ENCRYPTION_KEY=""


# ------------------------------------------------------------------------------
# 9. EXPERIMENTAL BRIDGES & EXTRA CHAIN CONFIGURATIONS
# ------------------------------------------------------------------------------

# Toggles showing experimental Solana/Stellar CCTP bridge tabs in the deposit UI ("true" / "false").
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_BRIDGES="false"

# --- Solana Bridge Setup ---
# Public Solana RPC endpoint (exposed to frontend).
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Private Solana RPC endpoint (used only on the server/backend). Defaults to NEXT_PUBLIC_SOLANA_RPC_URL.
SOLANA_RPC_URL=""

# API Key for Jupiter Aggregator. Used to quote and route swaps on Solana.
# Obtain from Jupiter Developer Portal (https://jup.ag).
JUPITER_API_KEY=""

# --- Stellar Bridge Setup ---
# Soroban smart contract RPC endpoint.
NEXT_PUBLIC_STELLAR_RPC_URL="https://soroban-rpc.mainnet.stellar.gateway.fm"

# Stellar Horizon REST API for querying account info, balances, and history.
NEXT_PUBLIC_STELLAR_HORIZON_URL="https://horizon.stellar.org"

# Network passphrase to configure the Stellar SDK.
# - Mainnet: "Public Global Stellar Network ; September 2015"
# - Testnet: "Test SDF Network ; September 2015"
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"

# Circle's TokenMessenger Soroban contract address on Stellar.
# Obtain from Circle CCTP Developer Documentation.
NEXT_PUBLIC_STELLAR_TOKEN_MESSENGER_CONTRACT=""

# USDC Token Contract address on Stellar.
# Default Mainnet USDC address is provided below.
NEXT_PUBLIC_STELLAR_USDC_CONTRACT="CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75"

# Optional: CctpForwarder Soroban contract address to route EVM-destined CCTP transfers.
NEXT_PUBLIC_STELLAR_CCTP_FORWARDER=""

# ------------------------------------------------------------------------------
# 11. STELLAR FEE SPONSORSHIP
# ------------------------------------------------------------------------------
# A funded Stellar account whose secret key is used to fee-bump user transactions.
# This lets users transact on Stellar using only USDC — they never need XLM for fees.
#
# How to set up:
#   1. Go to https://laboratory.stellar.org/#account-creator (use Testnet toggle for testnet)
#      OR generate a keypair at https://stellar.org/laboratory → "Generate Keypair"
#   2. Fund the account:
#      - Testnet: paste the public key into https://friendbot.stellar.org  (free 10,000 XLM)
#      - Mainnet: send ≥5 XLM from any exchange to the public key
#   3. Paste the SECRET key (S...) below — keep it server-side only, never expose to client
#
# Cost: each fee-bumped transaction costs ~0.00001 XLM. 5 XLM ≈ 500,000 sponsored txs.
# If not set: users pay their own tiny XLM fee (the account must have at least 1 XLM).
STELLAR_SPONSOR_SECRET_KEY=""